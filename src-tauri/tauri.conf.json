{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "GRC Command Center",
  "version": "0.1.0",
  "identifier": "com.grc.commandcenter",
  "build": {
    "beforeDevCommand": {
      "script": "trunk serve --port 1420 --open false",
      "cwd": "../frontend",
      "wait": false
    },
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": {
      "script": "trunk build --release",
      "cwd": "../frontend"
    },
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "GRC Command Center",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
